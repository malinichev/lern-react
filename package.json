{
  "name": "production-project",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start:dev:server\"",
    "dev:vite": "concurrently \"yarn start:vite\" \"yarn start:dev:server\"",
    "start:vite": "vite",
    "start": "webpack serve --env port=3000",
    "start:dev:server": "node ./json-server/index.js",
    "build:prod": "webpack  --env mode=production",
    "build:dev": "webpack  --env mode=development",
    "prettier": "npx prettier --write **/*.{ts,tsx}",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"**/*.{ts,tsx}\" --fix --quiet",
    "lint:scss": "npx stylelint \"**/*.scss\"",
    "lint:scss:fix": "npx stylelint \"**/*.scss\" --fix",
    "test:unit": "jest --config ./config/jest/jest.config.ts",
    "test:e2e": "cypress open",
    "test:ui": "npx loki test",
    "test:ui:ok": "npx loki approve",
    "test:ui:ci": "loki --requireReference --reactUri file:./storybook-static",
    "test:ui:report": "npm run test:ui:json && npm run test:ui:html",
    "test:ui:json": "node scripts/generate-visual-json-report.js",
    "test:ui:html": "reg-cli --from .loki/report.json --report .loki/report.html",
    "storybook": "storybook dev -p 6006 --config-dir ./config/storybook",
    "storybook:build": "storybook build --config-dir ./config/storybook",
    "generate:slice": "node ./scripts/createSlice/index.js",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "remove-feature": "ts-node ./scripts/remove-feature.ts",
    "prepare": "husky",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --list-different",
      "eslint"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
